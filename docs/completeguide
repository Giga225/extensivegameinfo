class SoundEffectPool {
private:
    std::vector<Mix_Chunk*> pool;
    std::vector<bool> inUse;
    
public:
    int playSound(const std::string& soundId) {
        for (int i = 0; i < pool.size(); i++) {
            if (!inUse[i]) {
                inUse[i] = true;
                Mix_PlayChannel(i, pool[i], 0);
                return i;
            }
        }
        // Pool exhausted, reuse oldest
        return 0;
    }
