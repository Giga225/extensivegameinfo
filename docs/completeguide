# PARTICLE EFFECTS & TRAILS

## Particle System
```cpp
struct Particle {
    Position pos;
    Velocity vel;
    float lifetime;
    float maxLifetime;
    SDL_Color color;
    float scale;
};

class ParticleSystem {
private:
    std::vector<Particle> particles;
    
public:
    void spawn(int count, Position origin, float speed) {
        for (int i = 0; i < count; i++) {
            Particle p;
            p.pos = origin;
            float angle = (rand() % 360) * M_PI / 180.0f;
            p.vel = {std::cos(angle) * speed, std::sin(angle) * speed};
            p.lifetime = 0.0f;
            p.maxLifetime = 1.0f;
            particles.push_back(p);
        }
    }
    
    void update(float dt) {
        particles.erase(
            std::remove_if(particles.begin(), particles.end(),
                [dt](Particle& p) {
                    p.lifetime += dt;
                    p.pos.x += p.vel.vx * dt;
                    p.pos.y += p.vel.vy * dt;
                    return p.lifetime >= p.maxLifetime;
                }),
            particles.end()
        );
    }
};
```

## Trails (Mud/Snow)
```cpp
struct TrailParticle {
    Position pos;
    float fade;
    float maxFade;
    TrailType type; // MUD, SNOW
};

class TrailSystem {
private:
    std::vector<TrailParticle> trails;
    
public:
    void addTrail(Position pos, TrailType type) {
        TrailParticle t;
        t.pos = pos;
        t.fade = 1.0f;
        t.maxFade = 5.0f; // Fade over 5 seconds
        t.type = type;
        trails.push_back(t);
    }
    
    void update(float dt) {
        trails.erase(
            std::remove_if(trails.begin(), trails.end(),
                [dt](TrailParticle& t) {
                    t.fade -= dt;
                    return t.fade <= 0.0f;
                }),
            trails.end()
        );
    }
};
