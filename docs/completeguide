## Input Manager Structure
```cpp
class InputManager {
private:
    std::map<std::string, SDL_Scancode> keyBindings;
    bool keyStates[SDL_NUM_SCANCODES];
    int mouseX, mouseY;
    
public:
    void update() {
        const uint8_t* state = SDL_GetKeyboardState(nullptr);
        std::copy(state, state + SDL_NUM_SCANCODES, keyStates);
    }
    
    bool isActionDown(const std::string& action) {
        auto it = keyBindings.find(action);
        if (it != keyBindings.end()) {
            return keyStates[it->second];
        }
        return false;
    }
    
    void remapKey(const std::string& action, SDL_Scancode key) {
        keyBindings[action] = key;
    }
};
