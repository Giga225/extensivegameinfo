# PERFORMANCE OPTIMIZATION

## Memory Pooling
```cpp
template<typename T>
class ObjectPool {
private:
    std::vector<T> pool;
    std::vector<bool> inUse;
    
public:
    ObjectPool(size_t initialSize) : pool(initialSize), inUse(initialSize, false) {}
    
    T* acquire() {
        for (size_t i = 0; i < inUse.size(); i++) {
            if (!inUse[i]) {
                inUse[i] = true;
                return &pool[i];
            }
        }
        // Expand pool
        pool.emplace_back();
        inUse.push_back(true);
        return &pool.back();
    }
    
    void release(T* obj) {
        for (size_t i = 0; i < pool.size(); i++) {
            if (&pool[i] == obj) {
                inUse[i] = false;
                return;
            }
        }
    }
};
```

## Culling
```cpp
bool isEntityVisible(const Entity& e, const Camera& camera) {
    auto pos = e.getComponent<Position>();
    auto sprite = e.getComponent<Sprite>();
    if (!pos || !sprite) return false;
    
    // Simple AABB check
    float left = pos->x;
    float right = pos->x + sprite->width;
    float top = pos->y;
    float bottom = pos->y + sprite->height;
    
    float camLeft = camera.x;
    float camRight = camera.x + camera.width;
    float camTop = camera.y;
    float camBottom = camera.y + camera.height;
    
    return !(right < camLeft || left > camRight ||
             bottom < camTop || top > camBottom);
}
```

## Batch Rendering
```cpp
class RenderBatch {
private:
    std::vector<SpriteDrawCall> calls;
    
public:
    void addSprite(SDL_Texture* tex, SDL_Rect src, SDL_Rect dest) {
        calls.push_back({tex, src, dest});
    }
    
    void flush(SDL_Renderer* renderer) {
        std::sort(calls.begin(), calls.end(),
            [](const SpriteDrawCall& a, const SpriteDrawCall& b) {
                return a.tex < b.tex; // Sort by texture
            });
        
        for (auto& call : calls) {
            SDL_RenderCopy(renderer, call.tex, &call.src, &call.dest);
        }
        calls.clear();
    }
};
```

