# ENEMY AI & BEHAVIOR

## State Machine
```cpp
enum class AIState { IDLE, PATROL, CHASE, ATTACK, FLEE, DEAD };

struct AIComponent {
    AIState state = AIState::IDLE;
    AIState nextState = AIState::IDLE;
    float stateTime = 0.0f;
    
    // Ranges
    float sightRange = 200.0f;
    float attackRange = 50.0f;
    float fleeThreshold = 0.3f; // Health percentage
    
    // Patrol
    std::vector<Position> patrolPoints;
    int currentPatrolIndex = 0;
};

void updateAI(Entity& enemy, float dt) {
    auto* ai = enemy.getComponent<AIComponent>();
    auto* pos = enemy.getComponent<Position>();
    auto* health = enemy.getComponent<Health>();
    
    ai->stateTime += dt;
    
    // State transitions
    float distToPlayer = distance(pos->x, pos->y, player.x, player.y);
    
    if (health->hp <= 0) {
        ai->nextState = AIState::DEAD;
    } else if (health->hp < health->maxHp * ai->fleeThreshold) {
        ai->nextState = AIState::FLEE;
    } else if (distToPlayer < ai->attackRange) {
        ai->nextState = AIState::ATTACK;
    } else if (distToPlayer < ai->sightRange) {
        ai->nextState = AIState::CHASE;
    } else {
        ai->nextState = AIState::PATROL;
    }
    
    // Execute state
    switch (ai->nextState) {
        case AIState::IDLE:
            // Do nothing
            break;
        case AIState::PATROL:
            // Move to next patrol point
            break;
        case AIState::CHASE:
            // Move toward player
            break;
        case AIState::ATTACK:
            // Attack player
            break;
        case AIState::FLEE:
            // Move away from player
            break;
        case AIState::DEAD:
            // Dead behavior
            break;
    }
}
