struct Inventory {
    std::vector<ItemInstance> items;
    float maxWeight;
    int maxSlots; // Also enforce slot limit
    
    bool canAddItem(const Item& item) {
        float totalWeight = 0.0f;
        for (auto& i : items) totalWeight += i.weight;
        return (totalWeight + item.weight <= maxWeight) && 
               (items.size() < maxSlots);
